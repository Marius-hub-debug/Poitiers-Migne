const PAGES=['home','membres','stats','recentes','random','game','chat','forum'];
function goTo(id){
  PAGES.forEach(s=>{
    document.getElementById('section-'+s).classList.remove('active');
    const n=document.getElementById('nav-'+s);if(n)n.classList.remove('active');
  });
  document.getElementById('section-'+id).classList.add('active');
  const n=document.getElementById('nav-'+id);if(n)n.classList.add('active');
  if(id==='game')initBoard();
}

