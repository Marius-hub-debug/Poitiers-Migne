function showAuth(p){
  ['page-login','page-register','app'].forEach(id=>document.getElementById(id).classList.add('hidden'));
  if(p==='login')    document.getElementById('page-login').classList.remove('hidden');
  if(p==='register') document.getElementById('page-register').classList.remove('hidden');
  if(p==='app')      document.getElementById('app').classList.remove('hidden');
}
// --- UTILITAIRE : Convertir un pseudo en faux email pour sb ---
function pseudoToEmail(pseudo) {
  return pseudo.trim().toLowerCase().replace(/[^a-z0-9]/g, '') + '@club.local';
}
