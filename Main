async function loadPendingUsers() {
  const { data, error } = await sb.from('profiles').select('*').eq('account_status', 'pending');
  const list = document.getElementById('pending-users-list');
  
  if (error || data.length === 0) {
    list.innerHTML = '<div class="empty-state"><div class="ei">✅</div><p>Aucun compte en attente.</p></div>';
    return;
  }

  list.innerHTML = data.map(p => `
    <div class="member-card" style="margin-bottom: 10px;">
      <div class="m-av av-1">${p.full_name.substring(0,2).toUpperCase()}</div>
      <div class="m-info">
        <div class="m-name">${p.full_name}</div>
        <div class="m-sub">Inscription récente</div>
      </div>
      <button class="btn-primary" style="background:var(--green);" onclick="acceptUser('${p.id}')">Accepter</button>
      <button class="btn-cancel" style="color:var(--red);" onclick="rejectUser('${p.id}')">Refuser</button>
    </div>
  `).join('');
}

async function acceptUser(userId) {
  await sb.from('profiles').update({ account_status: 'accepted' }).eq('id', userId);
  showToast('✅ Joueur accepté !');
  loadPendingUsers();
}

async function rejectUser(userId) {
  await sb.from('profiles').update({ account_status: 'rejected' }).eq('id', userId);
  showToast('❌ Joueur refusé.');
  loadPendingUsers();
}

/* ═══ REALTIME CHAT ═══ */
function listenToChatRealtime() {
  // Charger les messages existants
  fetchMessages(); 

  // Écouter les nouveaux messages en temps réel
  sb
    .channel('public:chat_messages')
    .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'chat_messages' }, payload => {
      const msg = payload.new;
      if (msg.channel === curCh) {
        // Ajouter le message à l'interface (simplifié ici, tu pourras faire une jointure pour le nom de l'auteur)
        CHAT[curCh].push({ author: "Membre", init: "?", col: 'av-1', t: msg.content, time: "Maintenant" });
        renderChat();
      }
    })
    .subscribe();
}

async function fetchMessages() {
    const { data } = await sb.from('chat_messages').select('*').eq('channel', curCh).order('created_at', { ascending: true });
    if(data) {
        CHAT[curCh] = data.map(m => ({ author: "Membre", init: "?", t: m.content, time: "..." }));
        renderChat();
    }
}
