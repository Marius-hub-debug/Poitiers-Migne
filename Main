  function enterApp(profile) {
  const init = profile.full_name.substring(0, 2).toUpperCase();
  me = { id: profile.id, name: profile.full_name, init: init, isAdmin: profile.is_admin };
  
  // Mise à jour de la barre latérale
  document.getElementById('sb-name').textContent = profile.full_name;
  document.getElementById('sb-avatar').textContent = init;
  document.getElementById('welcome-name').textContent = profile.full_name.split(' ')[0];
  
  // Affichage du panneau Admin si l'utilisateur l'est
  if (profile.is_admin) {
    document.getElementById('nav-lbl-admin').style.display = 'block';
    document.getElementById('nav-admin').style.display = 'flex';
    if (!PAGES.includes('admin')) PAGES.push('admin');
    loadPendingUsers();
  }
  
  showAuth('app');
  initCadGrid();
  renderTopics();
  loadMembers(); // <--- AJOUTÉ ICI : Charge la liste des joueurs
  listenToChatRealtime();
  goTo('home');
}
async function doLogin() {
  const pseudo = document.getElementById('reg-pseudo').value.trim();
  const pw = document.getElementById('login-pw').value;

  if (!pseudo || !pw) { showToast('⚠️ Veuillez remplir tous les champs.'); return; }

  const email = pseudoToEmail(pseudo);
  const { data, error } = await sb.auth.signInWithPassword({ email, password: pw });

  if (error) {
    showToast('❌ Identifiants incorrects.');
  } else {
    // Vérifier le statut de validation
    const { data: profile } = await sb.from('profiles').select('*').eq('id', data.user.id).single();
    
    if (profile.account_status === 'pending') {
      await sb.auth.signOut();
      showToast('⏳ Ton compte est en attente de validation par un admin.');
    } else if (profile.account_status === 'rejected') {
      await sb.auth.signOut();
      showToast('❌ Ton compte a été refusé.');
    } else {
      enterApp(profile);
      showToast('✅ Connexion réussie !');
    }
  }
}

async function doRegister() {
  const pseudo = document.getElementById('reg-pseudo').value.trim();
  const pw = document.getElementById('reg-pw').value;

  if (!pseudo || !pw) { showToast('⚠️ Veuillez remplir tous les champs.'); return; }
  if (pw.length < 8) { showToast('⚠️ Mot de passe trop court (8 min).'); return; }

  const email = pseudoToEmail(pseudo);
  const { error } = await sb.auth.signUp({ 
    email, 
    password: pw,
    options: { data: { full_name: pseudo } } // Passé au trigger SQL
  });

  if (error) {
    showToast('❌ Erreur : ' + error.message);
  } else {
    showToast('✅ Compte créé ! En attente de validation par un administrateur.');
    showAuth('login');
  }
}
  
