    document.getElementById('matched-name').textContent=matchedOpp.name;
    document.getElementById('matched-elo').textContent='ELO chargé depuis sb';
    cd.style.display='block';
  },2200);
}

/* ═══ CHAT ═══ */
function switchCh(ch,el){
  curCh=ch;
  document.querySelectorAll('.ch-item').forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('chat-ch-title').textContent='# '+ch.replace('-',' ');
  renderChat();
}
function renderChat(){
  const el=document.getElementById('chat-msgs');
  const msgs=CHAT[curCh]||[];
  el.innerHTML=msgs.map(m=>{
    if(m.sys)return`<div class="sys-msg">— ${m.t} —</div>`;
    const isMe=m.author===me.name;
    return`<div class="chat-msg${isMe?' me':''}">
      <div class="cm-av ${m.col||'av-1'}">${m.init||'?'}</div>
      <div><div><span class="cm-name">${m.author}</span><span class="cm-time">${m.time}</span></div>
      <div class="cm-text">${esc(m.t)}</div></div></div>`;
  }).join('');
  el.scrollTop=el.scrollHeight;
}
async function sendChat() {
  const inp = document.getElementById('chat-inp');
  const text = inp.value.trim();
  if (!text) return;

  const { error } = await sb
    .from('chat_messages')
    .insert([{ 
        channel: curCh, 
        content: text,
        author_id: (await sb.auth.getUser()).data.user.id 
    }]);

  if (error) showToast('Erreur d\'envoi');
  inp.value = '';
}
/* ═══ FORUM ═══ */
function renderTopics(){
  const list=document.getElementById('topics-list');
  list.innerHTML=[...TOPICS].reverse().map(t=>`
    <div class="topic-row" onclick="openTopic(${t.id})">
      <div class="topic-icon">${t.icon}</div>
      <div class="topic-info">
        <div class="topic-title">${esc(t.title)}</div>
        <div class="topic-sub">${t.cat} · par ${t.author}</div>
      </div>
      <div class="topic-meta">
        <div class="topic-count">${t.replies.length} réponse${t.replies.length>1?'s':''}</div>
        <div class="topic-date">${t.date}</div>
      </div>
    </div>`).join('');
}
function openTopic(id){
  curTopic=id;const t=TOPICS.find(t=>t.id===id);if(!t)return;
  document.getElementById('forum-list-view').style.display='none';
  document.getElementById('new-topic-form').style.display='none';
  document.getElementById('forum-detail').style.display='block';
  document.getElementById('detail-title').textContent=t.title;
  document.getElementById('detail-meta').textContent=`${t.cat} · ${t.date} · ${t.replies.length} réponse(s)`;
  document.getElementById('reply-inp').value='';
  renderPosts(t);
}
function renderPosts(t){
  document.getElementById('detail-posts').innerHTML=t.replies.map(r=>`
    <div class="forum-post">
      <div class="fp-hd">
        <div class="fp-av ${r.acol}">${r.ainit}</div>
        <div><div class="fp-name">${r.author}</div><div class="fp-date">${r.date}</div></div>
      </div>
      <div class="fp-body">${esc(r.body)}</div>
    </div>`).join('');
}
function backToForum(){
  document.getElementById('forum-detail').style.display='none';
  document.getElementById('forum-list-view').style.display='block';
  curTopic=null;
}
function toggleNTF(){
  const f=document.getElementById('new-topic-form');
  f.style.display=f.style.display==='block'?'none':'block';
}
function submitTopic(){
  const title=document.getElementById('ntf-title').value.trim();
  const cat=document.getElementById('ntf-cat').value;
  const body=document.getElementById('ntf-body').value.trim();
  if(!title||!body){showToast('⚠️ Titre et message requis.');return;}
  if(!me.name){showToast('Connectez-vous d\'abord.');return;}
  const date=new Date().toLocaleDateString('fr-FR',{day:'numeric',month:'long',year:'numeric'});
  const icon=cat.split(' ')[0];
  TOPICS.push({id:topicCtr++,icon,title,cat:cat.replace(/^.\s/,''),author:me.name,ainit:me.init,acol:'av-1',date,
    replies:[{author:me.name,ainit:me.init,acol:'av-1',date,body}]});
  // → sb.from('topics').insert(...)
  document.getElementById('ntf-title').value='';
  document.getElementById('ntf-body').value='';
  toggleNTF();renderTopics();showToast('✅ Sujet publié !');
}
function submitReply(){
  const text=document.getElementById('reply-inp').value.trim();
  if(!text){showToast('⚠️ Réponse vide.');return;}
  if(!me.name){showToast('Connectez-vous d\'abord.');return;}
  const t=TOPICS.find(t=>t.id===curTopic);if(!t)return;
  const date=new Date().toLocaleDateString('fr-FR',{day:'numeric',month:'long',year:'numeric'});
  t.replies.push({author:me.name,ainit:me.init,acol:'av-1',date,body:text});
  // → sb.from('replies').insert(...)
  document.getElementById('reply-inp').value='';
  renderPosts(t);
  document.getElementById('detail-meta').textContent=`${t.cat} · ${t.date} · ${t.replies.length} réponse(s)`;
  renderTopics();showToast('✅ Réponse publiée !');
}

/* ═══ CHESS ═══ */
let game=null,board=null,boardInited=false;

function updateStatus(){
  const turn=game.turn()==='w'?'Blancs':'Noirs';
  let s;
  if(game.in_checkmate())s='🏆 Échec et mat ! Victoire des '+(turn==='Blancs'?'Noirs':'Blancs');
  else if(game.in_draw())s='🤝 Match nul';
  else{s='Tour des '+turn;if(game.in_check())s+=' · ⚠️ Échec !';}
  document.getElementById('status-display').innerHTML=s;
}
function updateHistory(){
  const m=game.history();let h='';
  for(let i=0;i<m.length;i+=2){
    const n=Math.floor(i/2)+1;
    h+=`<span style="color:var(--g400);margin-right:2px">${n}.</span> ${m[i]||''} ${m[i+1]||''}<br>`;
  }
  const el=document.getElementById('history-display');
  el.innerHTML=h;el.scrollTop=el.scrollHeight;
}
function removeHL(){$('#board .square-55d63').removeClass('highlight');}
function addHL(sq){
  removeHL();
  game.moves({square:sq,verbose:true}).forEach(mv=>$('#board .square-'+mv.to).addClass('highlight'));
}
function onDrop(src,tgt){
  removeHL();
  const mv=game.move({from:src,to:tgt,promotion:'q'});
  if(!mv)return'snapback';
  board.position(game.fen());updateStatus();updateHistory();
}
function undoMove(){game.undo();board.position(game.fen());updateStatus();updateHistory();}
function resetGame(){game=new Chess();board.start();updateStatus();updateHistory();}

function initBoard(){
  if(boardInited)return;
  boardInited=true;
  game=new Chess();
  board=Chessboard('board',{
    draggable:true,
    position:'start',
    /* Wikipedia pieces hosted on chessboardjs.com — displayed correctly in browsers */
    pieceTheme:'https://chessboardjs.com/img/chesspieces/wikipedia/{piece}.png',
    onDrop:onDrop,
    onMouseoverSquare:sq=>addHL(sq),
    onMouseoutSquare:()=>removeHL(),
    onSnapEnd:()=>board.position(game.fen()),
  });
  updateStatus();updateHistory();
  /* Force repaint after section becomes visible */
  setTimeout(()=>{if(board){board.resize();}},80);
}

/* ═══ UTILS ═══ */
function esc(s){
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>');
}
</script>
