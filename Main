let modalOpp=null,matchedOpp=null;
function initCadGrid(){
  document.getElementById('cad-grid').innerHTML=CADENCES.map(c=>`
    <div class="cad-btn${c.id===selCad.id?' sel':''}" onclick="selCadence('${c.id}',this)">
      <div class="cad-nm">${c.nm}</div><div class="cad-sub">${c.sub}</div>
    </div>`).join('');
}
function selCadence(id,el){
  selCad=CADENCES.find(c=>c.id===id);
  document.querySelectorAll('.cad-btn').forEach(b=>b.classList.remove('sel'));
  el.classList.add('sel');
}
function openModal(opp){
  if(!opp)return;
  modalOpp=opp;
  const init=(opp.name||'?').split(' ').map(w=>w[0]).join('').substring(0,2).toUpperCase();
  const av=document.getElementById('modal-av');
  av.textContent=init; av.className='modal-opp-av '+(opp.col||'av-1');
  document.getElementById('modal-nm').textContent=opp.name||'—';
  document.getElementById('modal-elo').textContent=opp.elo?`ELO ${opp.elo}`:'ELO chargé depuis sb';
  document.getElementById('modal-ov').classList.remove('hidden');
}
function closeModal(){document.getElementById('modal-ov').classList.add('hidden');}
function confirmChallenge(){
  const name=modalOpp?modalOpp.name:'—';
  closeModal();goTo('game');
  document.getElementById('game-vs').textContent=`vs ${name} · ${selCad.nm} ${selCad.sub}`;
  setTimeout(()=>showToast(`⚔️ Défi envoyé à ${name} — ${selCad.t} (sb à venir)`),300);
}

